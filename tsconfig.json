{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["dom", "es2022"],
        "module": "es2022",
        "moduleResolution": "bundler",
        "noEmit": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "ts-node": {
        "compilerOptions": {
            "target": "es5",
            "lib": ["dom", "es2016"],
            "module": "commonjs",
            "moduleResolution": "node",
            "esModuleInterop": false,
            "noEmit": false
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
