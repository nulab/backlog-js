{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["dom", "es2022"],
        "module": "es2022",
        "moduleResolution": "bundler",
        "noEmit": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
